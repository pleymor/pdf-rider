<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <Identity
    Name="Pleymor.pdf-rider"
    Publisher="CN=B79D1225-9D8B-4940-8036-D7FDBD5EA2D3"
    Version="0.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>PDF Rider</DisplayName>
    <PublisherDisplayName>Pleymor</PublisherDisplayName>
    <Logo>icons\StoreLogo.png</Logo>
    <Description>A simple, lightweight PDF reader with annotations and signing</Description>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
    <Resource Language="fr-fr" />
  </Resources>

  <Applications>
    <Application Id="App" Executable="pdf-reader-portable.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="PDF Rider"
        Description="A simple, lightweight PDF reader with annotations and signing"
        BackgroundColor="transparent"
        Square150x150Logo="icons\Square150x150Logo.png"
        Square44x44Logo="icons\Square44x44Logo.png">
        <uap:DefaultTile Square71x71Logo="icons\Square71x71Logo.png" />
        <uap:SplashScreen Image="icons\Square310x310Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <uap:Extension Category="windows.fileTypeAssociation">
          <uap:FileTypeAssociation Name="pdf">
            <uap:SupportedFileTypes>
              <uap:FileType>.pdf</uap:FileType>
            </uap:SupportedFileTypes>
            <uap:DisplayName>PDF Document</uap:DisplayName>
          </uap:FileTypeAssociation>
        </uap:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
