import { VerticalBox, HorizontalBox, Button, ScrollView, LineEdit, Spinner } from "std-widgets.slint";

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: ta.has-hover && root.enabled ? #444 : transparent;

    Image {
        width: 16px;
        height: 16px;
        source: root.icon;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        opacity: root.enabled ? 1.0 : 0.3;
        colorize: #cccccc;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }
}

// Data model for a single page image in the viewer
export struct PageData {
    image: image,
    width: length,
    height: length,
    page-num: int,
    rendered: bool,
}

export component App inherits Window {
    title: "PDF Rider";
    preferred-width: 1280px;
    preferred-height: 800px;
    background: #1e1e1e;

    // Callbacks exposed to Rust
    callback open-file();
    callback zoom-in();
    callback zoom-out();
    callback fit-width();
    callback fit-height();
    callback rotate();
    callback page-prev();
    callback page-next();
    callback page-goto(int);
    callback viewport-changed(length, length);
    callback drop-file(string);

    // Properties bound from Rust
    in-out property <string> status-text: "No file open";
    in-out property <bool> has-document: false;
    in-out property <[PageData]> pages: [];
    in-out property <string> zoom-text: "150%";
    in-out property <string> page-text: "1";
    in-out property <int> page-count: 0;
    in-out property <int> current-page: 1;
    in-out property <bool> loading: false;
    // Expose window dimensions to Rust
    out property <float> viewer-width: self.width / 1px;
    out property <float> viewer-height: self.height / 1px;
    // Scroll control
    public function scroll-to(y: length) {
        viewer-scroll.viewport-y = y;
    }
    out property <float> current-scroll-y: -viewer-scroll.viewport-y / 1px;

    VerticalLayout {
        spacing: 0;

        // ── Toolbar ──
        Rectangle {
            height: 40px;
            background: #2d2d2d;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;
                // Center children vertically in the 40px bar
                padding-top: 6px;
                padding-bottom: 6px;

                // Open
                IconButton {
                    icon: @image-url("icons/open.svg");
                    clicked => { root.open-file(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                // Page navigation
                IconButton {
                    icon: @image-url("icons/page-up.svg");
                    enabled: root.current-page > 1;
                    clicked => { root.page-prev(); }
                }

                page-input := LineEdit {
                    width: 50px;
                    height: 28px;
                    text: root.page-text;
                    accepted(text) => {
                        root.page-goto(text.to-float());
                    }
                }

                Text {
                    text: "/ \{root.page-count}";
                    color: #cccccc;
                    vertical-alignment: center;
                }

                IconButton {
                    icon: @image-url("icons/page-down.svg");
                    enabled: root.current-page < root.page-count;
                    clicked => { root.page-next(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                // Zoom controls
                IconButton {
                    icon: @image-url("icons/zoom-out.svg");
                    clicked => { root.zoom-out(); }
                }

                Text {
                    text: root.zoom-text;
                    color: #cccccc;
                    vertical-alignment: center;
                    min-width: 40px;
                    horizontal-alignment: center;
                }

                IconButton {
                    icon: @image-url("icons/zoom-in.svg");
                    clicked => { root.zoom-in(); }
                }

                IconButton {
                    icon: @image-url("icons/fit-width.svg");
                    clicked => { root.fit-width(); }
                }

                IconButton {
                    icon: @image-url("icons/fit-height.svg");
                    clicked => { root.fit-height(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                IconButton {
                    icon: @image-url("icons/rotate.svg");
                    clicked => { root.rotate(); }
                }

                // Spacer
                Rectangle { }

                // Status
                Text {
                    text: root.status-text;
                    color: #888888;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        // ── PDF Viewer Area ──
        Rectangle {
            viewer-scroll := ScrollView {
                visible: root.has-document;

                VerticalLayout {
                    spacing: 8px;

                    for page-data in root.pages: HorizontalLayout {
                        alignment: center;

                        Rectangle {
                            width: page-data.width;
                            height: page-data.height;
                            background: page-data.rendered ? #ffffff : #333333;

                            if page-data.rendered: Image {
                                width: parent.width;
                                height: parent.height;
                                source: page-data.image;
                                image-fit: fill;
                            }
                            if !page-data.rendered: Text {
                                text: "Page \{page-data.page-num}";
                                color: #666666;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            if !root.has-document: Text {
                text: "Drop a PDF file here or click Open";
                color: #888888;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
