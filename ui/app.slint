import { VerticalBox, HorizontalBox, Button, ScrollView, LineEdit, Spinner, SpinBox } from "std-widgets.slint";

component IconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> enabled: true;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: ta.has-hover && root.enabled ? #444 : transparent;

    Image {
        width: 16px;
        height: 16px;
        source: root.icon;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        opacity: root.enabled ? 1.0 : 0.3;
        colorize: #cccccc;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }
}

component ToggleIconButton inherits Rectangle {
    in property <image> icon;
    in property <bool> active: false;
    in property <bool> enabled: true;
    callback clicked();

    width: 28px;
    height: 28px;
    border-radius: 4px;
    background: root.active ? #4d9eff : (ta.has-hover && root.enabled ? #444 : transparent);

    Image {
        width: 16px;
        height: 16px;
        source: root.icon;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        opacity: root.enabled ? 1.0 : 0.3;
        colorize: root.active ? #ffffff : #cccccc;
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
        mouse-cursor: root.enabled ? pointer : default;
    }
}

// Data model for a single page image in the viewer
export struct PageData {
    image: image,
    width: length,
    height: length,
    page-num: int,
    rendered: bool,
}

export component App inherits Window {
    title: "PDF Rider";
    icon: @image-url("../src-tauri/icons/icon.png");
    preferred-width: 1280px;
    preferred-height: 800px;
    background: #1e1e1e;

    // Callbacks exposed to Rust
    callback open-file();
    callback save-file();
    callback zoom-in();
    callback zoom-out();
    callback fit-width();
    callback fit-height();
    callback rotate();
    callback page-prev();
    callback page-next();
    callback page-goto(int);
    callback set-tool(string);
    // Pointer events on a page: (page-num, x-px, y-px)
    callback page-pointer-down(int, float, float);
    callback page-pointer-move(int, float, float);
    callback page-pointer-up(int, float, float);
    // Selection/move on a page
    callback page-click(int, float, float);
    callback page-drag-move(int, float, float);
    callback page-drag-end(int, float, float);
    callback delete-selected();
    callback set-color(int, int, int);
    callback set-stroke-width(int);
    callback set-font-size(int);
    // Resize: (handle-index 0=NW 1=NE 2=SW 3=SE, page, x, y)
    callback resize-start(int, int, float, float);
    callback resize-move(float, float);
    callback resize-end();

    // Properties bound from Rust
    in-out property <string> status-text: "No file open";
    in-out property <bool> has-document: false;
    in-out property <[PageData]> pages: [];
    in-out property <string> zoom-text: "150%";
    in-out property <string> page-text: "1";
    in-out property <int> page-count: 0;
    in-out property <int> current-page: 1;
    in-out property <bool> loading: false;
    in-out property <bool> edit-mode: false;
    in-out property <string> active-tool: "select";
    // Current drawing color (RGB 0-255)
    in-out property <int> cur-r: 255;
    in-out property <int> cur-g: 0;
    in-out property <int> cur-b: 0;
    // Selected annotation type for context styles
    in-out property <string> selection-type: ""; // "", "rect", "circle", "text", "signature"
    in-out property <int> cur-stroke-width: 2;
    in-out property <int> cur-font-size: 14;
    in-out property <bool> resizing: false;
    // Drawing preview (canvas pixel coords relative to the page being drawn on)
    in-out property <bool> drawing: false;
    in-out property <int> drawing-page: 0;
    in-out property <float> draw-x: 0;
    in-out property <float> draw-y: 0;
    in-out property <float> draw-w: 0;
    in-out property <float> draw-h: 0;
    // Selection highlight
    in-out property <bool> has-selection: false;
    in-out property <int> selection-page: 0;
    in-out property <float> sel-x: 0;
    in-out property <float> sel-y: 0;
    in-out property <float> sel-w: 0;
    in-out property <float> sel-h: 0;
    // Expose window dimensions to Rust
    out property <float> viewer-width: self.width / 1px;
    out property <float> viewer-height: self.height / 1px;
    // Scroll control
    public function scroll-to(y: length) {
        viewer-scroll.viewport-y = y;
    }
    out property <float> current-scroll-y: -viewer-scroll.viewport-y / 1px;

    VerticalLayout {
        spacing: 0;

        // ── Toolbar ──
        Rectangle {
            height: 40px;
            background: #2d2d2d;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                alignment: start;
                padding-top: 6px;
                padding-bottom: 6px;

                // Open
                IconButton {
                    icon: @image-url("icons/open.svg");
                    clicked => { root.open-file(); }
                }

                // Save
                IconButton {
                    icon: @image-url("icons/save.svg");
                    enabled: root.has-document;
                    clicked => { root.save-file(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                // Page navigation
                IconButton {
                    icon: @image-url("icons/page-up.svg");
                    enabled: root.current-page > 1;
                    clicked => { root.page-prev(); }
                }

                page-input := LineEdit {
                    width: 50px;
                    height: 28px;
                    text: root.page-text;
                    accepted(text) => {
                        root.page-goto(text.to-float());
                    }
                }

                Text {
                    text: "/ \{root.page-count}";
                    color: #cccccc;
                    vertical-alignment: center;
                }

                IconButton {
                    icon: @image-url("icons/page-down.svg");
                    enabled: root.current-page < root.page-count;
                    clicked => { root.page-next(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                // Zoom controls
                IconButton {
                    icon: @image-url("icons/zoom-out.svg");
                    clicked => { root.zoom-out(); }
                }

                Text {
                    text: root.zoom-text;
                    color: #cccccc;
                    vertical-alignment: center;
                    min-width: 40px;
                    horizontal-alignment: center;
                }

                IconButton {
                    icon: @image-url("icons/zoom-in.svg");
                    clicked => { root.zoom-in(); }
                }

                IconButton {
                    icon: @image-url("icons/fit-width.svg");
                    clicked => { root.fit-width(); }
                }

                IconButton {
                    icon: @image-url("icons/fit-height.svg");
                    clicked => { root.fit-height(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                IconButton {
                    icon: @image-url("icons/rotate.svg");
                    clicked => { root.rotate(); }
                }

                // Separator
                Rectangle { width: 1px; height: 28px; background: #555; }

                // Edit mode toggle
                ToggleIconButton {
                    icon: @image-url("icons/edit.svg");
                    active: root.edit-mode;
                    enabled: root.has-document;
                    clicked => {
                        root.edit-mode = !root.edit-mode;
                        if !root.edit-mode {
                            root.set-tool("select");
                            root.has-selection = false;
                        }
                    }
                }

                // Annotation tools (only in edit mode)
                if root.edit-mode: ToggleIconButton {
                    icon: @image-url("icons/select.svg");
                    active: root.active-tool == "select";
                    clicked => { root.set-tool("select"); }
                }

                if root.edit-mode: ToggleIconButton {
                    icon: @image-url("icons/rect.svg");
                    active: root.active-tool == "rect";
                    enabled: root.has-document;
                    clicked => { root.set-tool("rect"); }
                }

                if root.edit-mode: ToggleIconButton {
                    icon: @image-url("icons/circle.svg");
                    active: root.active-tool == "circle";
                    enabled: root.has-document;
                    clicked => { root.set-tool("circle"); }
                }

                if root.edit-mode: ToggleIconButton {
                    icon: @image-url("icons/text.svg");
                    active: root.active-tool == "text";
                    enabled: root.has-document;
                    clicked => { root.set-tool("text"); }
                }

                // Style controls — only visible in edit mode when annotation selected or drawing tool active
                if root.edit-mode && (root.has-selection || root.active-tool != "select"): Rectangle { width: 1px; height: 28px; background: #555; }

                if root.edit-mode && (root.has-selection || root.active-tool != "select"): HorizontalLayout {
                    spacing: 2px;

                    for col in [
                        {r: 255, g: 0,   b: 0},
                        {r: 0,   g: 0,   b: 255},
                        {r: 0,   g: 150, b: 0},
                        {r: 255, g: 165, b: 0},
                        {r: 128, g: 0,   b: 128},
                        {r: 0,   g: 0,   b: 0},
                        {r: 100, g: 100, b: 100},
                        {r: 255, g: 255, b: 255},
                    ]: Rectangle {
                        width: 18px;
                        height: 18px;
                        border-radius: 9px;
                        background: Colors.rgb(col.r, col.g, col.b);
                        border-color: col.r == root.cur-r && col.g == root.cur-g && col.b == root.cur-b ? #4d9eff : #666;
                        border-width: col.r == root.cur-r && col.g == root.cur-g && col.b == root.cur-b ? 2px : 1px;
                        TouchArea {
                            clicked => { root.set-color(col.r, col.g, col.b); }
                            mouse-cursor: pointer;
                        }
                    }
                }

                // Stroke width for rect/circle
                if root.selection-type == "rect" || root.selection-type == "circle" || root.active-tool == "rect" || root.active-tool == "circle": HorizontalLayout {
                    spacing: 4px;
                    Rectangle { width: 2px; }
                    Text { text: "W:"; color: #aaa; vertical-alignment: center; }
                    SpinBox {
                        width: 75px;
                        height: 28px;
                        minimum: 1;
                        maximum: 20;
                        value: root.cur-stroke-width;
                        edited(val) => { root.set-stroke-width(val); }
                    }
                }

                // Font size for text
                if root.selection-type == "text" || root.active-tool == "text": HorizontalLayout {
                    spacing: 4px;
                    Rectangle { width: 2px; }
                    Text { text: "Sz:"; color: #aaa; vertical-alignment: center; }
                    SpinBox {
                        width: 75px;
                        height: 28px;
                        minimum: 6;
                        maximum: 72;
                        value: root.cur-font-size;
                        edited(val) => { root.set-font-size(val); }
                    }
                }

                // Spacer
                Rectangle { }

                // Status
                Text {
                    text: root.status-text;
                    color: #888888;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        // ── PDF Viewer Area ──
        Rectangle {
            viewer-scroll := ScrollView {
                visible: root.has-document;

                VerticalLayout {
                    spacing: 8px;

                    for page-data in root.pages: HorizontalLayout {
                        alignment: center;

                        Rectangle {
                            width: page-data.width;
                            height: page-data.height;
                            background: page-data.rendered ? #ffffff : #333333;

                            if page-data.rendered: Image {
                                width: parent.width;
                                height: parent.height;
                                source: page-data.image;
                                image-fit: fill;
                            }
                            if !page-data.rendered: Text {
                                text: "Page \{page-data.page-num}";
                                color: #666666;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }

                            // Single full-page TouchArea that handles everything.
                            // Must be FIRST so it captures all events, then visual
                            // overlays are painted on top (they have no TouchArea).
                            page-ta := TouchArea {
                                enabled: root.edit-mode;
                                mouse-cursor: !root.edit-mode ? default :
                                    root.active-tool == "select" ?
                                    (root.resizing ? default : (root.has-selection && root.selection-page == page-data.page-num ? move : default)) :
                                    crosshair;
                                pointer-event(evt) => {
                                    if evt.kind == PointerEventKind.down && evt.button == PointerEventButton.left {
                                        if root.active-tool == "select" {
                                            root.page-click(page-data.page-num, self.mouse-x / 1px, self.mouse-y / 1px);
                                        } else {
                                            root.page-pointer-down(page-data.page-num, self.mouse-x / 1px, self.mouse-y / 1px);
                                        }
                                    }
                                    if evt.kind == PointerEventKind.up && evt.button == PointerEventButton.left {
                                        if root.resizing {
                                            root.resize-end();
                                        } else if root.active-tool == "select" {
                                            root.page-drag-end(page-data.page-num, self.mouse-x / 1px, self.mouse-y / 1px);
                                        } else {
                                            root.page-pointer-up(page-data.page-num, self.mouse-x / 1px, self.mouse-y / 1px);
                                        }
                                    }
                                }
                                moved => {
                                    if self.pressed {
                                        if root.resizing {
                                            root.resize-move(self.mouse-x / 1px, self.mouse-y / 1px);
                                        } else if root.active-tool == "select" {
                                            root.page-drag-move(page-data.page-num, self.mouse-x / 1px, self.mouse-y / 1px);
                                        } else {
                                            root.page-pointer-move(page-data.page-num, self.mouse-x / 1px, self.mouse-y / 1px);
                                        }
                                    }
                                }
                            }

                            // Drawing preview overlay
                            if root.drawing && root.drawing-page == page-data.page-num: Rectangle {
                                x: root.draw-x * 1px;
                                y: root.draw-y * 1px;
                                width: root.draw-w * 1px;
                                height: root.draw-h * 1px;
                                border-color: Colors.rgb(root.cur-r, root.cur-g, root.cur-b);
                                border-width: max(1px, root.cur-stroke-width * 1px);
                                background: transparent;
                                border-radius: root.active-tool == "circle" ? self.width / 2 : 0;
                            }

                            // Selection box + handles (visual only, no TouchArea)
                            if root.edit-mode && root.has-selection && root.selection-page == page-data.page-num: Rectangle {
                                x: root.sel-x * 1px - 5px;
                                y: root.sel-y * 1px - 5px;
                                width: root.sel-w * 1px + 10px;
                                height: root.sel-h * 1px + 10px;
                                border-color: #4d9eff;
                                border-width: 1.5px;
                                background: transparent;

                                // NW
                                Rectangle { x: -3px; y: -3px; width: 8px; height: 8px; background: white; border-color: #4d9eff; border-width: 1px; }
                                // NE
                                Rectangle { x: parent.width - 5px; y: -3px; width: 8px; height: 8px; background: white; border-color: #4d9eff; border-width: 1px; }
                                // SW
                                Rectangle { x: -3px; y: parent.height - 5px; width: 8px; height: 8px; background: white; border-color: #4d9eff; border-width: 1px; }
                                // SE
                                Rectangle { x: parent.width - 5px; y: parent.height - 5px; width: 8px; height: 8px; background: white; border-color: #4d9eff; border-width: 1px; }
                            }
                        }
                    }
                }
            }

            if !root.has-document: Text {
                text: "Drop a PDF file here or click Open";
                color: #888888;
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
